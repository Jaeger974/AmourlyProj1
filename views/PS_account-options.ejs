<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Amourly</title>
    <link rel="stylesheet" href="css/account-options.css"/>
</head>

<body>

<%- include("partials/PS_header.ejs") %>
<%- include("partials/alert") %>

<div class="account-options-container">
  <h2 class="account-options-title">Account Options</h2>

  <div class="options-buttons">
    <button class="edit-trigger" data-type="email">Change Email</button>
    <button class="edit-trigger" data-type="address">Change Address</button>
    <button class="edit-trigger" data-type="password">Change Password</button>
    <button class="edit-trigger" data-type="username">Change Username</button>
    <button class="edit-trigger" data-type="name">Change Name</button>
  </div>
</div>

<!-- Edit box OUTSIDE the container -->
<div id="edit-box" class="edit-box hidden">
  <div class="speech-arrow"></div>
  <h3 id="edit-title">Edit Field</h3>
  <div id="edit-fields"></div>
  <button id="edit-submit-btn" class="submit-btn">Submit</button>

  <div id="edit-confirmation" class="confirmation hidden">
    <p>Are you sure you want to update this information?</p>
    <button id="edit-confirm-yes" class="yes-btn">Yes, Submit</button>
    <button id="edit-confirm-no" class="no-btn">No, Edit Again</button>
  </div>
</div>

<!-- Bootstrap -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<!-- Your JS -->
<script src="/Clientside_JS/PoetrySub.js" type="module"></script>

<!-- UNIVERSAL EDIT BOX CONTROLLER -->
<script>
const editBox = document.getElementById("edit-box");
const editTitle = document.getElementById("edit-title");
const editFields = document.getElementById("edit-fields");
const submitBtn = document.getElementById("edit-submit-btn");
const confirmBox = document.getElementById("edit-confirmation");
const yesBtn = document.getElementById("edit-confirm-yes");
const noBtn = document.getElementById("edit-confirm-no");

let currentEditType = null;

// Open the box with dynamic fields
document.querySelectorAll(".edit-trigger").forEach(btn => {
  btn.addEventListener("click", () => {
    currentEditType = btn.dataset.type;
    editBox.classList.remove("hidden");
    confirmBox.classList.add("hidden");

    const rect = btn.getBoundingClientRect();
    const scrollY = window.scrollY;

    editBox.style.top = (rect.top + scrollY) + "px";
    editBox.style.left = (rect.right + 20) + "px";

    // Reset arrow position
    document.querySelector(".speech-arrow").style.top = "20px";

    switch (currentEditType) {
      case "email":
        editTitle.textContent = "Change Email";
        editFields.innerHTML = `
          <input type="email" id="field1" placeholder="New Email">
        `;
        break;

      case "address":
        editTitle.textContent = "Change Address";
        editFields.innerHTML = `
          <input type="text" id="field1" placeholder="Address Line 1">
          <input type="text" id="field2" placeholder="Address Line 2">
          <input type="text" id="field3" placeholder="City">
          <input type="text" id="field4" placeholder="Postcode">
        `;
        break;

      case "password":
        editTitle.textContent = "Change Password";
        editFields.innerHTML = `
          <input type="password" id="field1" placeholder="Current Password">
          <input type="password" id="field2" placeholder="New Password">
        `;
        break;

      case "username":
        editTitle.textContent = "Change Username";
        editFields.innerHTML = `
          <input type="text" id="field1" placeholder="New Username">
        `;
        break;

      case "name":
        editTitle.textContent = "Change Name";
        editFields.innerHTML = `
          <input type="text" id="field1" placeholder="First Name">
          <input type="text" id="field2" placeholder="Last Name">
        `;
        break;
    }
  });
});

// Show confirmation
submitBtn.addEventListener("click", () => {
  confirmBox.classList.remove("hidden");
});

// Cancel confirmation
noBtn.addEventListener("click", () => {
  confirmBox.classList.add("hidden");
});

// Submit to server
yesBtn.addEventListener("click", async () => {
  const payload = { type: currentEditType };

  [...editFields.querySelectorAll("input")].forEach((input, i) => {
    payload[`field${i+1}`] = input.value.trim();
  });

  const response = await fetch("/accountchanges", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(payload)
  });

  if (response.ok) {
    editBox.classList.add("hidden");
  }
});
</script>

<%- include("partials/PS_footer.ejs") %>

</body>
</html>