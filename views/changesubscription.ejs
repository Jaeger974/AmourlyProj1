<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit your subscription</title>

        <link rel="stylesheet" href="css/changesub.css"/> 
</head>
<body>

<%- include("partials/PS_header.ejs") %>
<%- include("partials/alert", { flash: flash }) %>


<main>
    <div class="change-subscription-container">
        <h2>Change Your Subscription</h2>

        <form action="/changesubscription" method="POST" class="change-subscription-form">


       <div class="recipient-details">

        <!-- Email Display Mode -->
        <div id="email-display">
            <p class="recipient-text">
            <strong>Recipient Email:</strong>
            <span><%= subscription.recipient_email %></span>
            </p>
            <button type="button" id="edit-email-btn" class="edit-button-email">
            Edit Email
            </button>
        </div>

        <!-- Email Edit Mode -->
        <div id="email-edit" style="display:none;">
            <label for="recipient-email">New Recipient Email</label>
            <input 
            type="email" 
            name="recipient-email"
            id="recipient-email"
            value="<%= subscription.recipient_email %>"
            required
            />
            <button type="button" id="cancel-email-btn">
            Cancel
            </button><button type="button" class="save-email-btn">Save</button>
        </div>
        <!--Preference display mode-->
        <div id="prefs-display">
            <p class="recipient-text">
            <strong>Recipient Preferences:</strong>
            <span><%= subscription.preferences %></span>
            </p>
            <button type="button" id="edit-prefs-btn" class="edit-button-prefs">
            Edit Preferences
            </button>
        </div>
        <!--Preference edit mode-->
        <div id="prefs-edit" style="display:none;">
            <label for="recipient-prefs">New Recipient Preferences</label>
            <input 
            type="text" 
            name="recipient-preferences"
            id="recipient-prefs"
            value="<%= subscription.preferences %>"
            />
            <button type="button" id="cancel-prefs-btn">
            Cancel
            </button><button type="button" class="save-prefs-btn">Save</button>
    </div>
    </div>

        <select id="sub-type" name="sub_type" required> 
        <option value="option1" <%= currentSub === 'option1' ? 'selected' : '' %>>
            School-ground Crush Subscription
        </option>

        <option value="option2" <%= currentSub === 'option2' ? 'selected' : '' %>>
            New Love Subscription
        </option>

        <option value="option3" <%= currentSub === 'option3' ? 'selected' : '' %>>
            Passionate Outpour Subscription
        </option>
    </select>

    <select id="freq-type" name="freq_type" required>
        <option value="option1" <%= currentFreq === 'option1' ? 'selected' : '' %>>
            Fortnightly
        </option>
        <option value="option2" <%= currentFreq === 'option2' ? 'selected' : '' %>>
            Monthly
        </option>
        <option value="option3" <%= currentFreq === 'option3' ? 'selected' : '' %>>
            Every 2 Months
        </option>
        <option value="option4" <%= currentFreq === 'option4' ? 'selected' : '' %>>
            Every 6 Months
        </option>
    </select>
                <button type="submit" class="update-subscription-button">Update Subscription</button>
            
    </div>

    <div id="address-section" style="display:none; margin-top:20px;">
        <p>Current Address: <%= subscription.recipient_address || 'N/A' %></p>
        <h3>Add New Recipient Address Here:</h3>

        <label>Address Line 1</label>
        <input type="text" name="address1">

        <label>Address Line 2</label>
        <input type="text" name="address2">

        <label>City</label>
        <input type="text" name="city">

        <label>Postcode</label>
        <input type="text" name="postcode">
    </div>
</form>
    <div>
    
    </div>


    <div id="confirmModal" class="modal">
        <div class="modal-content">
            <h3>Confirm Subscription Change</h3>
            <p>Are you sure you want to update your subscription?</p>

            <button id="confirmYes" class="modal-btn yes">Yes, update</button>
            <button id="confirmNo" class="modal-btn no">Cancel</button>
        </div>
    </div>
</main>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" src="/Clientside_JS/PoetrySub.js" type="module"></script>

<script src="//Clientside_JS/dateeditor-accountejs.js"></script>

 <script>
  const editBtn = document.getElementById("edit-email-btn");
  const cancelBtn = document.getElementById("cancel-email-btn");
  const displayDiv = document.getElementById("email-display");
  const editDiv = document.getElementById("email-edit");
  const saveBtn = document.querySelector(".update-email-btn");

  editBtn.addEventListener("click", () => {
    displayDiv.style.display = "none";
    editDiv.style.display = "block";
    document.getElementById("recipient-email").focus();
  });

  cancelBtn.addEventListener("click", () => {
    editDiv.style.display = "none";
    displayDiv.style.display = "block";
  });

  document.querySelector(".save-email-btn").addEventListener("click", () => {
  editDiv.style.display = "none";
  displayDiv.style.display = "block";
});

document.querySelector(".save-email-btn").addEventListener("click", () => {
  const newEmail = document.getElementById("recipient-email").value;

  document.querySelector("#email-display span").textContent = newEmail;

  editDiv.style.display = "none";
  displayDiv.style.display = "block";
});

</script>

<script>
  const editPrefsBtn = document.getElementById("edit-prefs-btn");
  const cancelPrefsBtn = document.getElementById("cancel-prefs-btn");
  const displayPrefsDiv = document.getElementById("prefs-display");
  const editPrefsDiv = document.getElementById("prefs-edit");
  const savePrefsBtn = document.querySelector(".save-prefs-btn");

  editPrefsBtn.addEventListener("click", () => {
    displayPrefsDiv.style.display = "none";
    editPrefsDiv.style.display = "block";
    document.getElementById("recipient-prefs").focus();

  });

  cancelPrefsBtn.addEventListener("click", () => {
    editPrefsDiv.style.display = "none";
    displayPrefsDiv.style.display = "block";
  });

    savePrefsBtn.addEventListener("click", () => {
    const newValue = document.getElementById("recipient-prefs").value;

    // Update the visible text BEFORE submission
    document.querySelector("#prefs-display span").textContent = newValue;

    editPrefsDiv.style.display = "none";
    displayPrefsDiv.style.display = "block";
    });

    document.querySelector(".save-prefs-btn").addEventListener("click", () => {
    editPrefsDiv.style.display = "none";
    displayPrefsDiv.style.display = "block";
    });
    
</script>

<script>
  const form = document.querySelector(".change-subscription-form");
  const modal = document.getElementById("confirmModal");
  const yesBtn = document.getElementById("confirmYes");
  const noBtn = document.getElementById("confirmNo");

  form.addEventListener("submit", function (e) {
    e.preventDefault();
    modal.style.display = "flex";
  });

  yesBtn.addEventListener("click", () => {
    modal.style.display = "none";
    form.submit();
  });

  noBtn.addEventListener("click", () => {
    modal.style.display = "none";
  });
</script>

<script>
  const subSelect = document.getElementById("sub-type");
  const addressSection = document.getElementById("address-section");

  function toggleAddressForm() {
    if (subSelect.value === "option3") {
      addressSection.style.display = "block";
    } else {
      addressSection.style.display = "none";
    }
  }

  subSelect.addEventListener("change", toggleAddressForm);

  // Run on page load in case option3 is already selected
  toggleAddressForm();
</script>


<%- include("partials/PS_footer.ejs") %>

</body>
</html>