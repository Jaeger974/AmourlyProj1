<% if (flash && flash.text) { %>
  <div class="alert-wrapper">
    <div class="alert <%= flash.type %> show" id="flash-alert">
      <%= flash.text %>
    </div>
  </div>

  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const alert = document.getElementById("flash-alert");
      if (!alert) return;

      setTimeout(() => {
        alert.classList.remove("show");
      }, 3000);
    });
  </script>
<% } %>