<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register New Account</title>
<link rel="stylesheet" href="/css/signupform.css"/> 
</head>
<body>

<div class="mainbody">
<div class="signup-container">
  <h2>Create Account</h2>

<% layout("partials/auth_layout", {
    title: "Register New Account",
    heading: "Join Our Poetry Subscription Service"
}) %>

<form action="/newsignup" method="POST" class="auth-form">

    <!-- First Name -->
    <div class="floating-group">
        <input type="text" id="firstName" name="firstName" placeholder=" " required>
        <label for="firstName">First Name</label>
    </div>

    <!-- Last Name -->
    <div class="floating-group">
        <input type="text" id="lastName" name="lastName" placeholder=" " required>
        <label for="lastName">Last Name</label>
    </div>

    <!-- Username -->
    <div class="floating-group">
        <input type="text" id="username" name="username" placeholder=" " required>
        <label for="username">Username</label>
    </div>

    <!-- Email -->
    <div class="floating-group">
        <input type="email" id="email" name="email" placeholder=" " required>
        <label for="email">Email Address</label>

        <% if (typeof message !== "undefined" && message) { %>
            <small class="error-message"><%= message %></small>
        <% } %>
    </div>

    <!-- Password -->
    <div class="floating-group">
        <input type="password" id="password" name="password" placeholder=" " required>
        <label for="password">Password</label>
    </div>

    <!-- Confirm Password -->
    <div class="floating-group">
        <input type="password" id="confirmPassword" name="confirmPassword" placeholder=" " required>
        <label for="confirmPassword">Confirm Password</label>
        <small id="passwordMessage"></small>
    </div>

    <!-- Address -->
    <h3>Your Address</h3>

    <div class="floating-group">
        <input type="text" id="addressLine1" name="addressLine1" placeholder=" " required>
        <label for="addressLine1">Address Line 1</label>
    </div>

    <div class="floating-group">
        <input type="text" id="addressLine2" name="addressLine2" placeholder=" ">
        <label for="addressLine2">Address Line 2</label>
    </div>

    <div class="floating-group">
        <input type="text" id="city" name="city" placeholder=" " required>
        <label for="city">Town/City</label>
    </div>

    <div class="floating-group">
        <input type="text" id="postcode" name="postcode" placeholder=" " required>
        <label for="postcode">Postcode / Zip Code</label>
    </div>

    <div class="floating-group">
        <input type="text" id="country" name="country" placeholder=" " required>
        <label for="country">Country</label>
    </div>

    <!-- Subscription -->
    <h4>Choose a Subscription level:</h4>
    <div class="radio-group">
        <div class="packageradio"><label><input type="radio" id="option1" name="sub_type" value="option1" <%= sub_type === 'option1' ? 'checked' : '' %> required> School-ground Crush</label></div>
        <div class="packageradio"><label><input type="radio" id="option2" name="sub_type" value="option2" <%= sub_type === 'option2' ? 'checked' : '' %> required> New Love Affair</label></div>
        <div class="packageradio"><label><input type="radio" id="option3" name="sub_type" value="option3"  <%= sub_type === 'option3' ? 'checked' : '' %> required> Passionate Outpour</label></div>
    </div>

    <!-- Frequency -->
    <h4>Select frequency of Delivery:</h4>
    <div class="radio-group2">
        <label><input type="radio" name="freq_type" value="option1" required> Every 2 weeks</label>
        <label><input type="radio" name="freq_type" value="option2" checked> Every Month</label>
        <label><input type="radio" name="freq_type" value="option3"> Every 2 Months</label>
        <label><input type="radio" name="freq_type" value="option4"> Every 6 Months</label>
    </div>

    <!-- Recipient Email -->
    <h3>Recipient Details</h3>

    <div class="floating-group">
        <input type="email" id="recipientEmail" name="recipientEmail" placeholder=" ">
        <label for="recipientEmail">Recipient Email</label>
    </div>

    <!-- Recipient Address -->
    <div id="recipientAddressContainer" class="hidden">

        <div class="floating-group">
            <input type="text" id="recipientAddressLine1" name="recipientAddressLine1" placeholder=" ">
            <label for="recipientAddressLine1">Recipient Address Line 1</label>
        </div>

        <div class="floating-group">
            <input type="text" id="recipientAddressLine2" name="recipientAddressLine2" placeholder=" ">
            <label for="recipientAddressLine2">Recipient Address Line 2</label>
        </div>

        <div class="floating-group">
            <input type="text" id="recipientCity" name="recipientCity" placeholder=" ">
            <label for="recipientCity">Recipient Town/City</label>
        </div>

        <div class="floating-group">
            <input type="text" id="recipientPostcode" name="recipientPostcode" placeholder=" ">
            <label for="recipientPostcode">Recipient Postcode / Zip Code</label>
        </div>

        <div class="floating-group">
            <input type="text" id="recipientCountry" name="recipientCountry" placeholder=" ">
            <label for="recipientCountry">Recipient Country</label>
        </div>
    </div>

    <!-- Price -->
    <div id="priceDisplay" class="price-box">
        Total Romantic Investment: <span id="priceValue"></span>
    </div>

    <input type="hidden" name="finalPrice" id="finalPriceInput">

    <button type="submit" class="auth-button">Continue to payment</button>

</form>

</div>
</div>

</body>



<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet"/>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" src="/Clientside_JS/PoetrySub.js" type="module"></script>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const option3Radio = document.getElementById("option3");
    const recipientContainer = document.getElementById("recipientAddressContainer");

    const recipientAddressLine1 = document.getElementById("recipientAddressLine1");
    const recipientCity = document.getElementById("recipientCity");
    const recipientPostcode = document.getElementById("recipientPostcode");
    const recipientCountry = document.getElementById("recipientCountry");

    const radios = document.querySelectorAll("input[name='sub_type']");

    function toggleRecipientFields() {
        const isOption3 = option3Radio.checked;

        // Required fields only when Option 3 is selected
        recipientAddressLine1.required = isOption3;
        recipientCity.required = isOption3;
        recipientPostcode.required = isOption3;
        recipientCountry.required = isOption3;

        // Show/hide container
        recipientContainer.classList.toggle("hidden", !isOption3);
    }

    // Listen for changes
    radios.forEach(radio => radio.addEventListener("change", toggleRecipientFields));

    // Run once on page load (important for preselected values)
    toggleRecipientFields();
});
</script>

 <script>
document.addEventListener("DOMContentLoaded", () => {
    const planRadios = document.querySelectorAll("input[name='sub_type']");
    const freqRadios = document.querySelectorAll("input[name=']");
    const priceValue = document.getElementById("priceValue");
    const finalPriceInput = document.getElementById("finalPriceInput");

    const prices = {
        option1: 3.99,
        option2: 9.99,
        option3: 24.99
    };

    const frequencyFactors = {
        option1: 2.4,   // Every 2 weeks
        option2: 1,     // Monthly
        option3: 0.7,   // Every 2 months
        option4: 0.4    // Every 6 months
    };

    function updatePrice() {
        const selectedPlan = document.querySelector("input[name='sub_type']:checked");
        if (!selectedPlan) return; // nothing selected yet

        const selectedFreq = document.querySelector("input[name='']:checked")?.value || "option2";

        const basePrice = prices[selectedPlan.value];
        const multiplier = frequencyFactors[selectedFreq];
        const finalPrice = (basePrice * multiplier).toFixed(2);

        priceValue.textContent = "£" + finalPrice + " per Month";
        finalPriceInput.value = finalPrice;
    }

    planRadios.forEach(r => r.addEventListener("change", updatePrice));
    freqRadios.forEach(r => r.addEventListener("change", updatePrice));

    updatePrice(); // run once on load
});
</script>

<script>
document.addEventListener("DOMContentLoaded", () => {
    const password = document.getElementById("password");
    const confirmPassword = document.getElementById("confirmPassword");
    const submitBtn = document.getElementById("submitBtn");
    const message = document.getElementById("passwordMessage");

    function validatePasswords() {
        if (!password.value || !confirmPassword.value) {
            confirmPassword.setCustomValidity("Please confirm your password");
            message.textContent = "";
            submitBtn.disabled = true;
            return;
        }

        if (password.value !== confirmPassword.value) {
            confirmPassword.setCustomValidity("Passwords do not match");
            message.textContent = "Passwords do not match ❌";
            message.style.color = "red";
            submitBtn.disabled = true;
        } else {
            confirmPassword.setCustomValidity("");
            message.textContent = "Passwords match ✅";
            message.style.color = "green";
            submitBtn.disabled = false;
        }
    }

    password.addEventListener("input", validatePasswords);
    confirmPassword.addEventListener("input", validatePasswords);
});
</script>

<script>
document.addEventListener("DOMContentLoaded", function () {
    const radios = document.querySelectorAll('.packageradio input[type="radio"]');

    radios.forEach(radio => {
        radio.addEventListener("change", function () {
            document.querySelectorAll('.packageradio label')
                .forEach(label => label.classList.remove("checked"));

            if (this.checked) {
                this.closest("label").classList.add("checked");
            }
        });
    });
});
</script>


</body>
</html>

